# ---------------------------------------------------------------------------
# Authentication — AI Platform (primary) or direct Claude API key (fallback)
# ---------------------------------------------------------------------------

# [OPTIONAL] AI Platform workspace ID.
# When set, the app exchanges this for a short-lived Anthropic API key automatically.
# Leave blank (or remove) to use ANTHROPIC_API_KEY directly instead.
WORKSPACE_ID=your_workspace_id_here

# [OPTIONAL] Direct Anthropic API key.
# Used as fallback when WORKSPACE_ID is not set.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------------------
# Model configuration
# ---------------------------------------------------------------------------

# Model for complex queries (trend analysis, multi-brand comparisons).
# AI Platform: use claude-sonnet-4-20250514
# Direct API:     use claude-sonnet-4-5-20251001 or claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Model for simple queries (single metric lookups).
# AI Platform: leave blank — sonnet will be used for all queries (haiku not available)
# Direct API:     use claude-3-5-haiku-20241022
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-20241022
